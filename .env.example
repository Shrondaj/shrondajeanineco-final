# ═══════════════════════════════════════════════
# SHRONDA JEANINE CO. — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# NEVER commit .env to Git
# ═══════════════════════════════════════════════

# Hugging Face API Key (FREE — for AI chat widget)
# Get yours FREE at: https://huggingface.co/settings/tokens
# Click "New token" → name it anything → copy it here
HF_API_KEY=hf_YOUR_TOKEN_HERE

# Stripe Keys (for course payments)
# Get yours at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_YOUR_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# Your live site URL (no trailing slash)
SITE_URL=https://shrondajeanineco.com

# Gmail credentials for sending booking/email notifications
# Use a Gmail App Password — NOT your regular password
# Guide: https://support.google.com/accounts/answer/185833
EMAIL_USER=shrondajeanine@shrondajeanineco.com
EMAIL_APP_PASS=YOUR_GMAIL_APP_PASSWORD

# Server port (optional, defaults to 3000)
PORT=3000
